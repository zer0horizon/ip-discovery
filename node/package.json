  "description": "Lightweight, high-performance library to discover your public IP address",
  "license": "MIT OR Apache-2.0",
  "author": "zer0horizon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zer0horizon/ip-discovery.git"
  },
